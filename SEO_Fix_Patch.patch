From 2cf1d397910a909bd36b9f1f2778368d294b1eda Mon Sep 17 00:00:00 2001
From: Kushal <kushal@vmukti.com>
Date: Mon, 6 Apr 2026 17:07:31 +0530
Subject: [PATCH] fix(seo): resolve title double-suffix, soft-404s, missing
 hreflang, and duplicate schemas

- Remove '| VMukti' suffix from all page titles in seo-config.js to prevent
  double-suffix with layout.js template '| VMukti Solutions'
- Fix corrupted VisualBot, Warehouse, and Transportation title entries
- Add 5 missing solution SEO configs (AI Video Analytics, Face Recognition,
  ANPR, Cloud Surveillance, Edge AI) and their slug mappings
- Fix hreflang by adding languages to alternates in generatePageMetadata()
- Import and call notFound() for unknown slugs in solution and industry pages
  to return proper HTTP 404 instead of soft-404 (200 with error content)
- Remove duplicate BreadcrumbList schema from solution-details-client.js
  (already handled globally by SEO/Breadcrumbs.jsx in site-layout)

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 app/industry/[name]/page.js                   |  14 ++-
 app/solution/[name]/page.js                   |  23 +++-
 .../[name]/solution-details-client.js         |  12 +-
 lib/metadata.js                               |  10 ++
 lib/seo-config.js                             | 109 +++++++++++++-----
 5 files changed, 121 insertions(+), 47 deletions(-)

diff --git a/app/industry/[name]/page.js b/app/industry/[name]/page.js
index 4fb5bd7..65d859d 100644
--- a/app/industry/[name]/page.js
+++ b/app/industry/[name]/page.js
@@ -1,7 +1,7 @@
 import { generatePageMetadata } from '../../../lib/metadata';
 import { seoConfig } from '../../../lib/seo-config';
 import IndustryDetailsClient from './industry-details-client';
-import { redirect } from 'next/navigation';
+import { redirect, notFound } from 'next/navigation';
 
 export const dynamic = 'force-dynamic';
 
@@ -35,14 +35,14 @@ export async function generateMetadata({ params }) {
   const { name } = await params;
   const configKey = industryMap[name];
   if (!configKey || !seoConfig[configKey]) {
-    return { title: 'Page Not Found' };
+    return { title: 'Page Not Found', robots: { index: false, follow: false } };
   }
   return generatePageMetadata(seoConfig[configKey], `/industry/${name}`);
 }
 
 export default async function IndustryDetailsPage({ params }) {
   const { name } = await params;
-  
+
   // Redirect non-canonical URLs to canonical ones
   if (name === 'oil-gas') {
     redirect('/industry/oil-and-gas');
@@ -51,6 +51,12 @@ export default async function IndustryDetailsPage({ params }) {
   if (name === 'sports-and-entertainment') {
     redirect('/industry/sports-entertainment');
   }
-  
+
+  // Return proper 404 for unknown industry slugs
+  const configKey = industryMap[name];
+  if (!configKey || !seoConfig[configKey]) {
+    notFound();
+  }
+
   return <IndustryDetailsClient industryName={name} />;
 }
